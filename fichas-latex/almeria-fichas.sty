\newcommand{\BloomColor}[1]{%
  \ifcsname BloomColor@#1\endcsname
    \csname BloomColor@#1\endcsname
  \else
    AlmGris%
  \fi
}

\newcommand{\BloomLabel}[1]{%
  \ifcsname BloomLabel@#1\endcsname
    \csname BloomLabel@#1\endcsname
  \else
    Nivel%
  \fi
}

\newcommand{\BloomSection}[1]{%
  \edef\AlmBloomColorActual{\BloomColor{#1}}%
  \begin{tcolorbox}[
    enhanced,
    breakable,
    colback=\AlmBloomColorActual!10,
    colframe=\AlmBloomColorActual,
    boxrule=1pt,
    arc=3mm,
    left=4mm,
    right=4mm,
    top=2mm,
    bottom=2mm,
    before skip=12pt,
    after skip=8pt]
    {\large\bfseries \BloomLabel{#1}}\\
    Resuelve con calma. Lee primero la consigna completa.
  \end{tcolorbox}
}

\newcommand{\BloomExercise}[5]{%
  \edef\AlmBloomColorActual{\BloomColor{#1}}%
  \begin{tcolorbox}[
    enhanced,
    breakable,
    colback=\AlmBloomColorActual!4,
    colframe=\AlmBloomColorActual,
    boxrule=0.9pt,
    arc=2mm,
    left=4mm,
    right=4mm,
    top=3mm,
    bottom=3mm,
    title={\textbf{\BloomLabel{#1} - Ejercicio #2: #3}},
    coltitle=black,
    colbacktitle=\AlmBloomColorActual!18,
    fonttitle=\bfseries,
    before skip=8pt,
    after skip=8pt]
    #4
    \RespuestaLineas{#5}
  \end{tcolorbox}
}

\newcommand{\RespuestaLineas}[1]{%
  \par\smallskip
  \begingroup
  \count255=0
  \loop\ifnum\count255<#1
    \advance\count255 by 1
    \noindent\textcolor{LineaSuave}{\rule{\linewidth}{0.45pt}}\par
    \vspace{0.85\baselineskip}
  \repeat
  \endgroup
}

\newcommand{\FichaCabecera}{%
