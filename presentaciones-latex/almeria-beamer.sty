% ---------------------------------------------------------------
%  COMANDOS DE AYUDA
% ---------------------------------------------------------------

% Tag de nivel Bloom (inline)
\newcommand{\bloomtag}[1]{%
  \tcbox[on line,
    colback=B#1, colframe=B#1,
    fontupper=\tiny\bfseries\color{white},
    nobeforeafter, boxsep=1.5pt, arc=2pt,
    left=2pt, right=2pt, top=1pt, bottom=1pt]{#1}%
  \xspace%
}

% Estrellas de dificultad (1-5)
\newcommand{\dificultad}[1]{%
  \foreach \i in {1,...,5}{%
    \ifnum\i>#1%
      \textcolor{gray!35}{$\bigstar$}%
    \else%
      \textcolor{AlmAmbar}{$\bigstar$}%
    \fi%
  }%
}

% Fórmula en caja centrada
\newcommand{\formuladest}[2][AlmAzulM]{%
  \begin{center}
    \tcbox[enhanced, colback=#1!9, colframe=#1,
           fontupper=\Large\bfseries, arc=5pt,
           boxsep=8pt, left=6pt, right=6pt]{$\displaystyle #2$}
  \end{center}%
}

% Dato de Almería (inline)
\newcommand{\datoalm}[2]{%
  {\color{AlmAzulM}\textbf{#1}}\,: #2%
}

% Fuente de datos (pie de diapositiva)
\newcommand{\fuente}[1]{%
  \vfill
  {\tiny\color{AlmGris}\faDatabase\enskip Fuente: #1}%
}

% Separador visual (línea ámbar)
\newcommand{\separador}{%
  \begin{tikzpicture}
    \draw[AlmAmbar, line width=1.2pt] (0,0) -- (\linewidth, 0);
  \end{tikzpicture}%
  \vspace{2pt}%
}

% Flecha de solución (paso a paso)
\newcommand{\pasoflechas}{%
  \begin{center}
    {\color{AlmAzulM}\Large$\Downarrow$}
  \end{center}%
}

% Tick verde / Cruz roja
\newcommand{\correcto}{\textcolor{AlmVerde}{\faCheckCircle}\xspace}
\newcommand{\incorrecto}{\textcolor{AlmTerra}{\faTimesCircle}\xspace}

% Unidad de medida destacada
\newcommand{\unidad}[1]{\textcolor{AlmAzulM}{\textbf{#1}}}

% Número de sesión en caja
\newcommand{\nsesion}[1]{%
  \tcbox[on line, colback=AlmAzul, colframe=AlmAzul,
         fontupper=\bfseries\color{AlmBlanco},
         nobeforeafter, boxsep=2pt, arc=3pt]{Sesión #1}%
}


% ---------------------------------------------------------------
%  ESTILO PGFPLOTS  (gráficas consistentes con la web)
% ---------------------------------------------------------------
\pgfplotsset{
  almeria/.style={
    axis lines=left,
    axis line style={AlmAzulM, line width=1pt},
    tick style={AlmAzulM},
    tick label style={font=\small, color=AlmNegro},
    label style={font=\small\bfseries, color=AlmAzul},
    grid=both,
    grid style={line width=0.3pt, AlmAzulC!30},
    major grid style={line width=0.5pt, AlmAzulC!50},
    title style={font=\small\bfseries, color=AlmAzul},
    legend style={
      font=\tiny, draw=AlmAzulM!50,
      fill=AlmFondo, rounded corners=2pt
    },
    width=0.95\linewidth,
    height=0.72\linewidth,
  },
  almeria bar/.style={
    almeria,
    ybar,
    bar width=0.55cm,
    enlarge x limits=0.15,
    nodes near coords,
    nodes near coords style={font=\tiny\bfseries, color=AlmAzul},
  },
  almeria line/.style={
    almeria,
    smooth,
    mark size=2.5pt,
  },
}


