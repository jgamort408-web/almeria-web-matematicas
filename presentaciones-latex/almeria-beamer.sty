% Tag de nivel Bloom (inline)
\newcommand{\bloomtag}[1]{%
  \tcbox[on line,
    colback=B#1, colframe=B#1,
    fontupper=\AlmFontBloomTag\bfseries\color{white},
    nobeforeafter, boxsep=\AlmBloomBoxSep, arc=\AlmBloomArc,
    left=\AlmBloomLeft, right=\AlmBloomRight,
    top=\AlmBloomTop, bottom=\AlmBloomBottom]{#1}%
  \xspace%
}

% Estrellas de dificultad (1-5)
\newcommand{\dificultad}[1]{%
  \foreach \i in {1,...,5}{%
    \ifnum\i>#1%
      \textcolor{gray!35}{$\bigstar$}%
    \else%
      \textcolor{AlmAmbar}{$\bigstar$}%
    \fi%
  }%
}

% Fórmula en caja centrada
\newcommand{\formuladest}[2][AlmAzulM]{%
  \begin{center}
    \tcbox[enhanced, colback=#1!9, colframe=#1,
           fontupper=\AlmFontFormulaDest\bfseries, arc=\AlmFormulaDestArc,
           boxsep=\AlmFormulaDestBoxSep, left=\AlmFormulaDestLeft, right=\AlmFormulaDestRight]{$\displaystyle #2$}
  \end{center}%
}

% Dato de Almería (inline)
\newcommand{\datoalm}[2]{%
  {\color{AlmAzulM}\textbf{#1}}\,: #2%
}

% Fuente de datos (pie de diapositiva)
\newcommand{\fuente}[1]{%
  \vfill
  {{\AlmFontFuente}\color{AlmGris}\faDatabase\enskip Fuente: #1}%
}

% Separador visual (línea ámbar)
\newcommand{\separador}{%
  \begin{tikzpicture}
    \draw[AlmAmbar, line width=\AlmSeparatorLineWidth] (0,0) -- (\linewidth, 0);
  \end{tikzpicture}%
  \vspace{\AlmSeparatorVSpace}%
}

% Flecha de solución (paso a paso)
\newcommand{\pasoflechas}{%
  \begin{center}
    {\color{AlmAzulM}\AlmArrowSize$\Downarrow$}
  \end{center}%
}

% Tick verde / Cruz roja
\newcommand{\correcto}{\textcolor{AlmVerde}{\faCheckCircle}\xspace}
\newcommand{\incorrecto}{\textcolor{AlmTerra}{\faTimesCircle}\xspace}

% Unidad de medida destacada
\newcommand{\unidad}[1]{\textcolor{AlmAzulM}{\textbf{#1}}}

% Número de sesión en caja
\newcommand{\nsesion}[1]{%
  \tcbox[on line, colback=AlmAzul, colframe=AlmAzul,
         fontupper=\AlmFontSesionTag\bfseries\color{AlmBlanco},
         nobeforeafter, boxsep=\AlmSesionBoxSep, arc=\AlmSesionArc]{Sesión #1}%
}


