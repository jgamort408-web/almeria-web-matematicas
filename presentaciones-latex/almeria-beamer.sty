  },
  puntov/.style={
    circle, fill=AlmVerde, inner sep=2.2pt, draw=AlmBlanco, line width=0.8pt
  },
  % Etiqueta de punto
  etiqueta/.style={
    font=\small\bfseries, color=AlmAzulM, above right
  },
  % Segmento / recta
  recto/.style={AlmAzulM, line width=1.5pt},
  rectot/.style={AlmTerra, line width=1.5pt},
  rectov/.style={AlmVerde, line width=1.5pt},
  % Ángulo
  arco/.style={draw=AlmTerra, line width=0.8pt},
  % Flecha de acotación
  acota/.style={
    <->, >=Stealth, AlmGris, line width=0.8pt,
    shorten <=2pt, shorten >=2pt
  },
  % Sombreado de zona (área)
  zona/.style={fill=AlmAzulC, fill opacity=0.18, draw=AlmAzulM, line width=0.8pt},
  zonat/.style={fill=AlmTerra, fill opacity=0.15, draw=AlmTerra, line width=0.8pt},
  zonav/.style={fill=AlmVerde, fill opacity=0.15, draw=AlmVerde, line width=0.8pt},
  % Cuadradito de ángulo recto
  rectoang/.style={draw=AlmAzulM, line width=0.7pt, fill=none},
}


