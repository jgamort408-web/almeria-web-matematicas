\definecolor{AlmVerde}{HTML}{2E7D32}     % verde         --verde-med
\definecolor{AlmFondo}{HTML}{F0F4F8}     % fondo claro
\definecolor{AlmGris}{HTML}{546E7A}      % gris secundario
