% ---------------------------------------------------------------
%  TÍTULO DE DIAPOSITIVA (frametitle)
% ---------------------------------------------------------------
\setbeamertemplate{frametitle}{%
  \nointerlineskip
  \begin{beamercolorbox}[%
      wd=\paperwidth,
      ht=\AlmFrameTitleHt,
      dp=\AlmFrameTitleDp,
      leftskip=\AlmFrameTitleLeftSkip,
      rightskip=\AlmFrameTitleRightSkip]{frametitle}%
    \vspace{\AlmFrameTitleInnerVSpace}%
    \usebeamerfont{frametitle}\insertframetitle%
    \ifx\insertframesubtitle\empty\else
      \hfill{{\AlmFontFrameSubtitle\color{AlmAmbar!90}\insertframesubtitle}}%
    \fi
  \end{beamercolorbox}%
  \nointerlineskip
  \begin{tikzpicture}[baseline=0pt]
    \fill[AlmAmbar] (0,0) rectangle (\paperwidth, \AlmFrameTitleRuleHeight);
  \end{tikzpicture}%
  \vspace{\AlmFrameTitleAfterVSpace}%
}


% ---------------------------------------------------------------
%  PIE DE PÁGINA (footline)
% ---------------------------------------------------------------
\setbeamertemplate{footline}{%
  \leavevmode%
  \begin{beamercolorbox}[%
      wd=\paperwidth,
      ht=\AlmFootlineHt,
      dp=\AlmFootlineDp,
      leftskip=\AlmFootlineLeftSkip,
      rightskip=\AlmFootlineRightSkip]{footline}%
    \usebeamerfont{footline}%
    {\color{AlmAmbar!80}\faMapMarkerAlt}\,%
    {\color{AlmBlanco!80}\ProjectName}%
    \hfill
    {\color{AlmBlanco}\BlockName\enskip$\cdot$\enskip\SessionName}%
    \hfill
    {\color{AlmBlanco!65}\insertframenumber\,/\,\inserttotalframenumber}%
  \end{beamercolorbox}%
}


% ---------------------------------------------------------------
%  PORTADA (title page)
% ---------------------------------------------------------------
\defbeamertemplate*{title page}{almeria}{%
  % Fondo completo azul marino
  \begin{tikzpicture}[remember picture, overlay]
    \fill[AlmAzul]
      (current page.south west) rectangle (current page.north east);

    % Ola inferior decorativa
    \fill[AlmAzulM, opacity=0.45]
      (current page.south west) --
      ([yshift=\AlmTitlePageWaveSouthY]current page.south west) ..controls
      ([xshift=\AlmTitlePageWaveSouthControlAX,yshift=\AlmTitlePageWaveSouthControlAY]current page.south west) and
      ([xshift=\AlmTitlePageWaveSouthControlBX,yshift=\AlmTitlePageWaveSouthControlBY]current page.south east) ..
      ([yshift=\AlmTitlePageWaveSouthY]current page.south east) --
      (current page.south east) -- cycle;

    % Ola superior sutil
    \fill[AlmAzulO, opacity=0.40]
      (current page.north west) --
      ([yshift=\AlmTitlePageWaveNorthY]current page.north west) ..controls
      ([xshift=\AlmTitlePageWaveNorthControlAX,yshift=\AlmTitlePageWaveNorthControlAY]current page.north west) and
      ([xshift=\AlmTitlePageWaveNorthControlBX,yshift=\AlmTitlePageWaveNorthControlBY]current page.north east) ..
      ([yshift=\AlmTitlePageWaveNorthY]current page.north east) --
      (current page.north east) -- cycle;

    % Franja dorada superior
    \fill[AlmAmbar]
      ([yshift=\AlmTitlePageTopBandA]current page.north west)
      rectangle
      ([yshift=\AlmTitlePageTopBandB]current page.north east);

    % Franja dorada inferior
    \fill[AlmAmbar!70]
      (current page.south west)
      rectangle
      ([yshift=\AlmTitlePageBottomBand]current page.south east);

    % Círculos decorativos
    \fill[AlmAmbar, opacity=0.08]
      ([xshift=\AlmTitlePageCircleAX, yshift=\AlmTitlePageCircleAY]current page.north east)
      circle (\AlmTitlePageCircleARadius);

    \fill[AlmAzulM, opacity=0.18]
      ([xshift=\AlmTitlePageCircleBX, yshift=\AlmTitlePageCircleBY]current page.north east)
      circle (\AlmTitlePageCircleBRadius);

    % Badge número de sesión
    \node[
      circle,
      draw=AlmAmbar,
      line width=\AlmTitlePageBadgeBorder,
      fill=AlmAzulM!80!AlmAzul,
      minimum size=\AlmTitlePageBadgeSize,
      text=AlmBlanco,
      font=\AlmFontTitlePageBadge\bfseries,
      anchor=center
    ] at ([xshift=\AlmTitlePageBadgeShiftX, yshift=\AlmTitlePageBadgeShiftY]current page.north east)
      (badge) {\SessionNumber};

    \node[
      above=\AlmTitlePageBadgeLabelGap of badge,
      text=AlmAmbar,
      font=\AlmFontTitlePageBadgeLabel\bfseries\sffamily,
      anchor=south
    ] {SESIÓN};

    % Badge bloque
    \node[
      rounded corners=3pt,
      fill=AlmAmbar,
      text=AlmAzulO,
      font=\AlmFontTitlePageBlockBadge\bfseries\sffamily,
      anchor=north,
      inner sep=\AlmTitlePageBlockBadgeInnerSep
    ] at ([xshift=\AlmTitlePageBadgeShiftX, yshift=\AlmTitlePageBlockBadgeShiftY]current page.north east)
      {\BlockName};
  \end{tikzpicture}

  % Contenido
  \vskip\AlmTitlePageTopSkip
  \begin{columns}[c]
    \begin{column}{\AlmTitlePageColumnsLeft}
      {\color{AlmAmbar}{\AlmFontTitlePageProject}\bfseries
        \faMapMarkerAlt\quad\ProjectName}%
      \par\vspace{\AlmTitlePageProjectGap}

      {\color{AlmBlanco}{\AlmFontTitlePageTitle}\bfseries\SessionTitle}%
      \par\vspace{\AlmTitlePageTitleGap}

      {\color{AlmBlanco!65}{\AlmFontTitlePageMeta}
        Sesión \SessionNumber\ $\cdot$\ \SchoolSubject\ $\cdot$\ \SchoolYear}%
      \par\vspace{\AlmTitlePageMetaGap}

      % Caja objetivo
      \begin{tcolorbox}[
        enhanced,
        sharp corners,
        colback=AlmAzulM!55!AlmAzul,
        colframe=AlmAmbar,
        boxrule=\AlmObjectiveBoxRule,
        leftrule=\AlmObjectiveLeftRule,
        boxsep=\AlmObjectiveBoxSep,
        arc=\AlmObjectiveArc,
        width=\AlmObjectiveWidth,
        before skip=0pt,
        after skip=0pt
      ]
        {\color{AlmAmbar}\bfseries\AlmFontTitlePageObjectiveLabel \faBookOpen\enspace OBJETIVO\quad}%
        {\color{AlmBlanco!90}\AlmFontTitlePageObjectiveText\SessionObjective}%
      \end{tcolorbox}

      \par\vspace{\AlmTitlePageAuthorGap}

      {\color{AlmBlanco!40}\AlmFontTitlePageAuthor
        \faUserTie\;\AuthorName
        \quad\textbar\quad
        \faSchool\;\InstituteName
        \quad\textbar\quad
        \faBook\;\SchoolSubject}
    \end{column}
    \begin{column}{\AlmTitlePageColumnsRight}
      % Badge en overlay TikZ
    \end{column}
  \end{columns}
}
\setbeamertemplate{title page}[almeria]


% ---------------------------------------------------------------
%  DIAPOSITIVA DE SECCIÓN  (separador entre secciones)
% ---------------------------------------------------------------
\newcommand{\seccionframe}[2][AlmAzulM]{%
  \begingroup
    \setbeamercolor{background canvas}{bg=#1}
    \begin{frame}[plain, c]
      \begin{tikzpicture}[remember picture, overlay]
        % Franja ámbar izquierda
        \fill[AlmAmbar]
          (current page.south west)
          rectangle
          ([xshift=\AlmSectionSideBand]current page.north west);

        % Franja ámbar derecha
        \fill[AlmAmbar, opacity=0.35]
          ([xshift=-\AlmSectionSideBand]current page.south east)
          rectangle
          (current page.north east);
      \end{tikzpicture}

      \begin{center}
        \vspace{\AlmSectionTopVSpace}
        {\color{AlmAmbar}\rule{\AlmSectionRuleWidth}{\AlmSectionRuleHeight}}\\[\AlmSectionRuleGap]
        {\color{AlmBlanco}{\AlmFontSectionPage}\bfseries #2}\\[\AlmSectionRuleGap]
        {\color{AlmAmbar}\rule{\AlmSectionRuleWidth}{\AlmSectionRuleHeight}}
      \end{center}
    \end{frame}
  \endgroup
}


