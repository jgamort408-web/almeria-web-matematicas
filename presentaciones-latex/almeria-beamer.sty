%  ESTILOS TIKZ  (diagramas geométricos)
% ---------------------------------------------------------------
\tikzset{
  % Punto en coordenadas
  punto/.style={
    circle, fill=AlmAzulM, inner sep=2.2pt, draw=AlmBlanco, line width=0.8pt
  },
  puntot/.style={
