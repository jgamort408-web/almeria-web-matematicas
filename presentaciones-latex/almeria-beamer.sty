% ---------------------------------------------------------------
%  TEMA BEAMER — configuración general
% ---------------------------------------------------------------
\usetheme{default}
\setbeamertemplate{navigation symbols}{}   % sin botones de navegación

% -- Colores del tema --
\setbeamercolor{normal text}{fg=AlmNegro, bg=AlmBlanco}
\setbeamercolor{structure}{fg=AlmAzul}
\setbeamercolor{frametitle}{fg=AlmBlanco, bg=AlmAzul}
\setbeamercolor{title}{fg=AlmBlanco, bg=AlmAzul}
\setbeamercolor{subtitle}{fg=AlmAmbar, bg=AlmAzul}
\setbeamercolor{alerted text}{fg=AlmTerra}
\setbeamercolor{example text}{fg=AlmVerde}
\setbeamercolor{block title}{fg=AlmBlanco, bg=AlmAzulM}
\setbeamercolor{block body}{fg=AlmNegro, bg=AlmFondo}
\setbeamercolor{block title alerted}{fg=AlmBlanco, bg=AlmTerra}
\setbeamercolor{block body alerted}{fg=AlmNegro, bg=AlmTerra!8}
\setbeamercolor{block title example}{fg=AlmBlanco, bg=AlmVerde}
\setbeamercolor{block body example}{fg=AlmNegro, bg=AlmVerde!8}
\setbeamercolor{itemize item}{fg=AlmAzulM}
\setbeamercolor{itemize subitem}{fg=AlmTerra}
\setbeamercolor{enumerate item}{fg=AlmAzulM}
\setbeamercolor{footline}{fg=AlmBlanco, bg=AlmAzul}
\setbeamercolor{section in toc}{fg=AlmAzul}
\setbeamercolor{subsection in toc}{fg=AlmAzulM}
\setbeamercolor{separator line}{fg=AlmAmbar}

% -- Fuentes del tema --
\setbeamerfont{title}{size=\Large, series=\bfseries}
\setbeamerfont{subtitle}{size=\small}
\setbeamerfont{frametitle}{size=\large, series=\bfseries}
\setbeamerfont{block title}{size=\normalsize, series=\bfseries}
\setbeamerfont{footline}{size=\scriptsize}
\setbeamerfont{section in toc}{size=\normalsize, series=\bfseries}

% -- Viñetas --
\setbeamertemplate{itemize item}{{\color{AlmAzulM}$\blacktriangleright$}}
\setbeamertemplate{itemize subitem}{{\color{AlmTerra}\textbullet}}
\setbeamertemplate{itemize subsubitem}{{\color{AlmVerde}$\circ$}}
\setbeamertemplate{enumerate item}{\color{AlmAzulM}\textbf{\arabic{enumi}.}}
\setbeamertemplate{enumerate subitem}{\color{AlmTerra}\alph{enumii})}


% ---------------------------------------------------------------
%  TÍTULO DE DIAPOSITIVA (frametitle)
% ---------------------------------------------------------------
\setbeamertemplate{frametitle}{%
  \nointerlineskip
  \begin{beamercolorbox}[wd=\paperwidth, ht=0.68cm, dp=0.22cm,
      leftskip=0.5cm, rightskip=0.5cm]{frametitle}%
    \vspace{0.05cm}%
    \usebeamerfont{frametitle}\insertframetitle%
    \ifx\insertframesubtitle\empty\else
      \hfill{\small\color{AlmAmbar!90}\insertframesubtitle}%
    \fi
  \end{beamercolorbox}%
  \nointerlineskip
  \begin{tikzpicture}[baseline=0pt]
    \fill[AlmAmbar] (0,0) rectangle (\paperwidth, 2.5pt);
  \end{tikzpicture}%
  \vspace{-2pt}%
}


% ---------------------------------------------------------------
%  PIE DE PÁGINA (footline)
% ---------------------------------------------------------------
\setbeamertemplate{footline}{%
  \leavevmode%
  \begin{beamercolorbox}[wd=\paperwidth, ht=0.46cm, dp=0.18cm,
      leftskip=0.45cm, rightskip=0.45cm]{footline}%
    \usebeamerfont{footline}%
    {\color{AlmAmbar!80}\faMapMarkerAlt}\,%
    {\color{AlmBlanco!80}\ProjectName}%
    \hfill
    {\color{AlmBlanco}\BlockName\enskip$\cdot$\enskip\SessionName}%
    \hfill
    {\color{AlmBlanco!65}\insertframenumber\,/\,\inserttotalframenumber}%
  \end{beamercolorbox}%
}


% ---------------------------------------------------------------
%  PORTADA (title page)
% ---------------------------------------------------------------
\defbeamertemplate*{title page}{almeria}{%
  % Fondo completo azul marino
  \begin{tikzpicture}[remember picture, overlay]
    \fill[AlmAzul]
      (current page.south west) rectangle (current page.north east);
    % Ola inferior decorativa
    \fill[AlmAzulM, opacity=0.45]
      (current page.south west) --
      ([yshift=3.2cm]current page.south west) ..controls
      ([xshift=4cm,yshift=3.8cm]current page.south west) and
      ([xshift=-4cm,yshift=2.8cm]current page.south east) ..
      ([yshift=3.2cm]current page.south east) --
      (current page.south east) -- cycle;
    % Franja dorada superior
    \fill[AlmAmbar]
      ([yshift=-3pt]current page.north west)
      rectangle
      ([yshift=-10pt]current page.north east);
    % Círculo decorativo (esquina superior derecha)
    \fill[AlmAmbar, opacity=0.10]
      ([xshift=-0.8cm, yshift=-0.8cm]current page.north east) circle (4.8cm);
    \fill[AlmAzulM, opacity=0.20]
      ([xshift=-2.5cm, yshift=-2.5cm]current page.north east) circle (3.2cm);
    % Badge número de sesión
    \node[
      circle, draw=AlmAmbar, line width=2.2pt,
      fill=AlmAzulM, minimum size=3cm,
      text=AlmBlanco, font=\bfseries\huge,
      anchor=center
    ] at ([xshift=-2.2cm, yshift=-2.2cm]current page.north east)
      (badge) {\SessionNumber};
    \node[above=3pt of badge, text=AlmAmbar,
          font=\tiny\bfseries\sffamily, anchor=south] {SESIÓN};
    % Badge bloque
    \node[
      rounded corners=3pt, fill=AlmAmbar!85!white,
      text=AlmAzul, font=\tiny\bfseries\sffamily,
      anchor=north, inner sep=4pt
    ] at ([xshift=-2.2cm, yshift=-4cm]current page.north east) {\BlockName};
  \end{tikzpicture}

  % Contenido
  \vskip0.55cm
  \begin{columns}[c]
    \begin{column}{0.73\textwidth}
      {\color{AlmAmbar}\footnotesize\bfseries
        \faMapMarkerAlt\quad\ProjectName}%

      {\color{AlmBlanco}\LARGE\bfseries\SessionTitle}%

      {\color{AlmBlanco!65}\small
        Sesión \SessionNumber\ $\cdot$\ \SchoolSubject\ $\cdot$\ \SchoolYear}%

      % Caja objetivo
      \begin{tcolorbox}[
        enhanced, sharp corners,
        colback=AlmAzulM!55!AlmAzul,
        colframe=AlmAmbar,
        boxrule=1pt, leftrule=3pt,
        boxsep=5pt, arc=3pt,
        width=0.95\textwidth,
        before skip=0pt, after skip=0pt
      ]
        {\color{AlmAmbar}\bfseries\tiny OBJETIVO\quad}%
        {\color{AlmBlanco!90}\small\SessionObjective}%
      \end{tcolorbox}

      {\color{AlmBlanco!45}\tiny
        \faUserTie\;\AuthorName
        \quad\textbar\quad
        \faSchool\;\InstituteName
        \quad\textbar\quad
        \faBookOpen\;\SchoolSubject
      }
    \end{column}
    \begin{column}{0.27\textwidth}
      % El badge está en el overlay TikZ
    \end{column}
  \end{columns}
}
\setbeamertemplate{title page}[almeria]


% ---------------------------------------------------------------
%  DIAPOSITIVA DE SECCIÓN  (separador entre secciones)
% ---------------------------------------------------------------
\newcommand{\seccionframe}[2][AlmAzulM]{%
  \begingroup
    \setbeamercolor{background canvas}{bg=#1}
    \begin{frame}[plain, c]
      \begin{center}
        \begin{tikzpicture}
          \draw[AlmAmbar, line width=1.8pt] (-3.5,0) -- (3.5,0);
        \end{tikzpicture}
        {\color{AlmBlanco}\huge\bfseries #2}
        \begin{tikzpicture}
          \draw[AlmAmbar, line width=1.8pt] (-3.5,0) -- (3.5,0);
        \end{tikzpicture}
      \end{center}
    \end{frame}
  \endgroup
}


